% --- Beispiel: Zeitschriftenartikel ---
@article{grieves2014,
  author  = {Grieves, Michael},
  title   = {Digital Twin: Manufacturing Excellence Through Virtual Factory Replication},
  journal = {White Paper},
  year    = {2014}
}

% --- Beispiel: Konferenzbeitrag ---
@inproceedings{lee2006,
  author    = {Lee, Jay and Bagheri, Behrad and Kao, Hung-An},
  title     = {A Cyber-Physical Systems Architecture for Industry 4.0-Based
               Manufacturing Systems},
  booktitle = {Manufacturing Letters},
  volume    = {3},
  pages     = {18--23},
  year      = {2015}
}

% --- Beispiel: Buch ---
@book{mobley2002,
  author    = {Mobley, R. Keith},
  title     = {An Introduction to Predictive Maintenance},
  publisher = {Butterworth-Heinemann},
  address   = {Oxford},
